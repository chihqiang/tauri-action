{
  "name": "tauri-action",
  "version": "0.1.0",
  "description": "Build, sign, and publish Tauri v2 apps with updater support",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsup",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src/",
    "lint:fix": "eslint src/ --fix",
    "format": "prettier --check src/",
    "format:fix": "prettier --write src/",
    "fix": "run-s format:fix lint:fix",
    "prepublish": "run-s format lint test build"
  },
  "keywords": [
    "github-action",
    "tauri",
    "release",
    "updater"
  ],
  "author": "chihqiang",
  "license": "Apache-2.0",
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/node": "^20.10.0",
    "eslint": "^10.4.1",
    "eslint-config-prettier": "^10.1.8",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.3",
    "tsup": "^8.0.0",
    "typescript": "^5.3.0",
    "typescript-eslint": "^8.60.1",
    "vitest": "^4.1.7"
  },
  "dependencies": {
    "@actions/core": "^1.10.0",
    "@actions/exec": "^1.1.0",
    "@actions/github": "^6.0.0"
  }
}
